@startuml
title Activity: Add Transaction
start
:User opens "Add Transaction" dialog;
:Enter amount + choose category;
:Select month/year;
if (Amount empty?) then (yes)
  :Show error;
  stop
endif
if (Budget exists for month/year?) then (no)
  :Prompt "Add Budget";
  if (User chooses Add Budget?) then (yes)
    :Open "Add Budget" dialog;
    :Create/Update budget;
  else (cancel)
    stop
  endif
endif
:Get budget warning (80%+);
if (Warning message?) then (yes)
  :Ask user "Continue?";
  if (Continue?) then (no)
    stop
  endif
endif
:Validate transaction vs budget;
:Insert transaction into DB;
:Deduct from budget in DB;
:Log activity;
:Show "Transaction saved";
stop
@enduml